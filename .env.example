# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── MercadoPago ───────────────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
MERCADOPAGO_PUBLIC_KEY=APP_USR-...
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-...
# Secreto para validar firmas HMAC del webhook — MP Dashboard › Webhooks › Secreto
MERCADOPAGO_WEBHOOK_SECRET=your_webhook_secret

# ── CJ Dropshipping ───────────────────────────────────────────────────────────
CJ_API_KEY=your_cj_api_key

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://theia.vercel.app
# Clave interna para operaciones admin — mínimo 32 caracteres aleatorios
ADMIN_SECRET_KEY=random_secret_32_chars_min

# ── Playwright / Scraper (solo servidor, no funciona en Vercel serverless) ────
# Proxy residencial requerido para scraping de Shein
SCRAPER_PROXY_URL=http://user:pass@host:port
# Ruta a archivo de cookies exportado de Shein (opcional)
SCRAPER_COOKIES_PATH=./shein-cookies.json
